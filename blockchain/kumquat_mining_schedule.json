  "lottery_logic": {
    "method": "hash_derived_deterministic_lottery",
    "overview": "The PoW solution hash is the sole entropy source for the denomination lottery.",
    "mechanics": {
      "step_1_solve_block": "Miner finds nonce where hash(block_header + nonce) meets difficulty target. Standard PoW.",
      "step_2_unit_count": "Extract bits [0..31] as uint32. Use Poisson distribution with lambda = avg_units_per_block for current era. This determines how many units (0, 1, or 2+) this block produces. In later eras with lower rates, many blocks produce 0. In early eras, some blocks produce 2.",
      "step_3_denomination_per_unit": "For each unit produced, extract successive 32-bit windows from the hash. Map each to denomination ranges using cumulative probabilities for the current era.",
      "step_4_era_from_height": "era = block_height / 63115200. Pure math, no clock."
    },
    "properties": {
      "deterministic": "Any node verifies lottery from block hash alone",
      "unforgeable": "Changing outcome requires re-solving PoW",
      "no_external_randomness": "All entropy from hash",
      "self_verifying": "Every minted unit's denomination recomputable from block hash",
      "no_wasted_blocks": "Even when avg > 1 unit/block, the system handles it via multi-unit rewards"
    }
  },
