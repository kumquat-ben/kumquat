aws_region         = "us-west-2"
project_name       = "kumquat"
environment        = "production"
availability_zones = ["us-west-2a", "us-west-2b", "us-west-2c"]

vpc_cidr = "10.40.0.0/16"

public_subnet_cidrs = [
  "10.40.0.0/24",
  "10.40.1.0/24",
  "10.40.2.0/24",
]

private_subnet_cidrs = [
  "10.40.10.0/24",
  "10.40.11.0/24",
  "10.40.12.0/24",
]

isolated_subnet_cidrs = [
  "10.40.20.0/24",
  "10.40.21.0/24",
  "10.40.22.0/24",
]

vpn_client_cidr = "172.20.0.0/22"

client_vpn_server_certificate_arn     = "arn:aws:acm:us-west-2:111122223333:certificate/replace-me"
client_vpn_root_certificate_chain_arn = "arn:aws:acm:us-west-2:111122223333:certificate/replace-me"

allowed_app_ingress_cidrs = []
public_app_load_balancer  = true

app_ingress_acm_certificate_arn = "arn:aws:acm:us-west-2:111122223333:certificate/replace-me"
ssh_key_name                    = null

k3s_server_instance_type = "m6i.large"
k3s_worker_instance_type = "m6i.large"
k3s_worker_min_size      = 2
k3s_worker_desired_size  = 2
k3s_worker_max_size      = 6
k3s_server_ami_id        = null
k3s_worker_ami_id        = null

ecr_repositories = {
  sample_app      = "sample-app"
  website_backend = "website-backend"
  mysql_backup    = "mysql-backup"
}

tags = {
  Owner = "platform-team"
}
