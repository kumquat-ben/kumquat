# Backend application settings
DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=kumquat.info,.kumquat.info,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://kumquat.info,http://localhost:8000
DJANGO_TIME_ZONE=UTC

# Google OAuth settings
GOOGLE_OAUTH_CLIENT_ID=replace-me
GOOGLE_OAUTH_CLIENT_SECRET=replace-me
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/auth/google/callback

# Vonage inbound SMS webhook settings
VONAGE_ACCOUNT_SECRET=
VONAGE_SMS_SIGNATURE_SECRET=
VONAGE_SMS_SIGNATURE_ALGORITHM=md5hash

# GitHub settings
GITHUB_TOKEN=replace-me

# Local backend database settings
MYSQL_DATABASE=kumquat
MYSQL_USER=kumquat
MYSQL_PASSWORD=replace-me
MYSQL_HOST=localhost
MYSQL_PORT=3306

# Container build and image tags
AWS_REGION=us-west-2
ACCOUNT_ID=351381968847
BACKEND_IMAGE_REPOSITORY=351381968847.dkr.ecr.us-west-2.amazonaws.com/website-backend
BACKEND_IMAGE_TAG=backend-20260407-1

# Kumquat platform addon deployment settings
KUMQUAT_KUBECONFIG_PATH=/path/to/kubeconfig
KUMQUAT_HOSTNAME=kumquat.info
KUMQUAT_NAMESPACE=kumquat
KUMQUAT_MYSQL_OPERATOR_NAMESPACE=mysql-operator
KUMQUAT_MYSQL_DATABASE_NAME=kumquat
KUMQUAT_MYSQL_APP_USER=kumquat
KUMQUAT_MYSQL_ROOT_PASSWORD=replace-me
KUMQUAT_MYSQL_APP_PASSWORD=replace-me
KUMQUAT_MYSQL_STORAGE_SIZE=50Gi
KUMQUAT_MYSQL_STORAGE_CLASS_NAME=kumquat-mysql-gp3
